rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // THE OVENS SECRET - CUSTOM CAKES & TREATS
    // Security Guardrails for Customer Feedback
    
    match /customer_feedback/{userId} {
      
      // Allow anybody to read the 10 most recent reviews
      allow read: if true;
      
      // 1. Cyber-attack protection: Must be authenticated (even anonymously)
      // 2. ID integrity: The user's ID must match the document ID
      // 3. Document structure validation: Ensure required fields and correct data types
      allow write: if request.auth != null 
                  && request.auth.uid == userId
                  && request.resource.data.author is string
                  && request.resource.data.author.size() < 100
                  && request.resource.data.quote is string
                  && request.resource.data.quote.size() < 1000
                  && request.resource.data.userId == request.auth.uid;
      
      // Allow users to delete only their own reviews
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
